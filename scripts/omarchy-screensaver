#!/usr/bin/env bash
set -euo pipefail

branding_file="${XDG_CONFIG_HOME:-$HOME/.config}/hypr/branding/screensaver.txt"
log=/tmp/hypr-omarchy-screensaver.log

printf '[%s] screensaver started on %s\n' "$(date -Is)" "$(tty 2>/dev/null || printf unknown)" >> "$log"

screensaver_in_focus() {
  hyprctl activewindow -j | jq -e '.class == "org.omarchy.screensaver"' >/dev/null 2>&1
}

exit_screensaver() {
  printf '[%s] screensaver exiting\n' "$(date -Is)" >> "$log"
  hyprctl keyword cursor:invisible false >/dev/null 2>&1 || true
  pkill -x tte 2>/dev/null || true
  exit 0
}

trap exit_screensaver INT TERM HUP QUIT

printf '\033]11;rgb:00/00/00\007'
hyprctl keyword cursor:invisible true >/dev/null 2>&1 || true

tty_name=$(tty 2>/dev/null || true)
tty_name=${tty_name#/dev/}

while true; do
  tte -i "$branding_file" \
    --frame-rate 120 \
    --canvas-width 0 \
    --canvas-height 0 \
    --reuse-canvas \
    --anchor-canvas c \
    --anchor-text c \
    --random-effect \
    --no-eol \
    --no-restore-cursor 2>> "$log" &

  while pgrep -t "$tty_name" -x tte >/dev/null 2>&1; do
    if read -r -n1 -t 1 || ! screensaver_in_focus; then
      exit_screensaver
    fi
  done
done

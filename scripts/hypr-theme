#!/usr/bin/env bash
set -euo pipefail

CONFIG_DIR="${HYPR_CONFIG_DIR:-$HOME/.config/hypr}"
OMARCHY_THEMES_DIR="$CONFIG_DIR/themes/omarchy"
HYPR_THEME_FILE="$CONFIG_DIR/themes/current.conf"
WAYBAR_THEME_FILE="$CONFIG_DIR/waybar/theme.css"
WAYBAR_CONFIG_FILE="$CONFIG_DIR/waybar/config.jsonc"
WAYBAR_STYLE_FILE="$CONFIG_DIR/waybar/style.css"

usage() {
  cat <<USAGE
Usage:
  scripts/hypr-theme list
  scripts/hypr-theme apply <theme>

Examples:
  scripts/hypr-theme list
  scripts/hypr-theme apply tokyo-night
  scripts/hypr-theme apply catppuccin
USAGE
}

list_themes() {
  find "$OMARCHY_THEMES_DIR" -mindepth 2 -maxdepth 2 -name colors.toml -printf '%h\n' \
    | sed 's#.*/##' \
    | sort
}

color_value() {
  local key="$1"
  local file="$2"

  awk -F '"' -v key="$key" '$1 ~ "^" key " *= *" { print $2; exit }' "$file"
}

strip_hash() {
  printf '%s' "${1#\#}"
}

rgb_tuple() {
  local hex
  hex="$(strip_hash "$1")"

  printf '%d, %d, %d' "0x${hex:0:2}" "0x${hex:2:2}" "0x${hex:4:2}"
}

write_theme() {
  local theme="$1"
  local colors="$OMARCHY_THEMES_DIR/$theme/colors.toml"

  if [[ ! -f "$colors" ]]; then
    printf 'Unknown theme: %s\n\nAvailable themes:\n' "$theme" >&2
    list_themes >&2
    exit 1
  fi

  local accent foreground background color0 color1 color2 color3
  accent="$(color_value accent "$colors")"
  foreground="$(color_value foreground "$colors")"
  background="$(color_value background "$colors")"
  color0="$(color_value color0 "$colors")"
  color1="$(color_value color1 "$colors")"
  color2="$(color_value color2 "$colors")"
  color3="$(color_value color3 "$colors")"

  if [[ -z "$accent" || -z "$foreground" || -z "$background" ]]; then
    printf 'Theme is missing required colors: %s\n' "$colors" >&2
    exit 1
  fi

  color0="${color0:-$background}"
  color1="${color1:-$accent}"
  color2="${color2:-$accent}"
  color3="${color3:-$accent}"

  cat >"$HYPR_THEME_FILE" <<EOF
# Generated by scripts/hypr-theme from Omarchy theme: $theme
# Source palette: themes/omarchy/$theme/colors.toml

\$theme_accent_a = rgba($(strip_hash "$accent")ff)
\$theme_accent_b = rgba($(strip_hash "$color2")ff)
\$theme_inactive_border = rgba($(strip_hash "$color0")cc)
\$theme_shadow = rgba($(strip_hash "$background")cc)
\$theme_group_active = rgba($(strip_hash "$accent")26)
\$theme_group_inactive = rgba($(strip_hash "$foreground")10)
\$theme_text = rgb($(strip_hash "$foreground"))
\$theme_text_dim = rgba($(strip_hash "$foreground")90)
EOF

  cat >"$WAYBAR_THEME_FILE" <<EOF
/* Generated by scripts/hypr-theme from Omarchy theme: $theme */
/* Source palette: themes/omarchy/$theme/colors.toml */

@define-color bg rgba($(rgb_tuple "$background"), 0.94);
@define-color bg-strong rgba($(rgb_tuple "$background"), 0.98);
@define-color fg $foreground;
@define-color muted rgba($(rgb_tuple "$foreground"), 0.58);
@define-color dim rgba($(rgb_tuple "$foreground"), 0.46);
@define-color border rgba($(rgb_tuple "$accent"), 0.25);
@define-color accent $accent;
@define-color accent-soft rgba($(rgb_tuple "$accent"), 0.18);
@define-color accent-2 $color2;
@define-color urgent rgba($(rgb_tuple "$color1"), 0.35);
@define-color warning $color3;
@define-color critical $color1;
@define-color critical-bg rgba($(rgb_tuple "$color1"), 0.24);
EOF

  printf 'Applied theme: %s\n' "$theme"
  reload_session
}

reload_session() {
  if command -v hyprctl >/dev/null 2>&1; then
    hyprctl reload >/dev/null 2>&1 || true
  fi

  if command -v waybar >/dev/null 2>&1 && command -v pkill >/dev/null 2>&1; then
    pkill -x waybar >/dev/null 2>&1 || true

    if command -v systemd-run >/dev/null 2>&1; then
      systemd-run --user --collect --unit=hypr-waybar \
        --setenv="WAYLAND_DISPLAY=${WAYLAND_DISPLAY:-}" \
        --setenv="XDG_CURRENT_DESKTOP=${XDG_CURRENT_DESKTOP:-Hyprland}" \
        --setenv="HYPRLAND_INSTANCE_SIGNATURE=${HYPRLAND_INSTANCE_SIGNATURE:-}" \
        waybar -c "$WAYBAR_CONFIG_FILE" -s "$WAYBAR_STYLE_FILE" >/dev/null 2>&1 && return
    fi

    setsid waybar -c "$WAYBAR_CONFIG_FILE" -s "$WAYBAR_STYLE_FILE" >/dev/null 2>&1 &
  fi
}

case "${1:-}" in
  list)
    list_themes
    ;;
  apply)
    if [[ -z "${2:-}" ]]; then
      usage >&2
      exit 1
    fi
    write_theme "$2"
    ;;
  "" | -h | --help | help)
    usage
    ;;
  *)
    usage >&2
    exit 1
    ;;
esac
